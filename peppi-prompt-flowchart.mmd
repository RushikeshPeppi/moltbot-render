flowchart TB
    %% ============================================================
    %% PEPPI SYSTEM PROMPT ASSEMBLY - COMPLETE DATA FLOW
    %% ============================================================

    %% =================== ENTRY POINT ===================
    USER_SMS["User Sends SMS via Twilio
    Example Message: 'Hey, how are you'"]

    PEPPI_BACKEND["Peppi Laravel Backend
    Receives SMS via Twilio webhook
    Identifies: user_id, buddy_id = 725,
    user_uuid = eff67a70-00f9-11f1-bbd8-ed635f290324"]

    USER_SMS --> PEPPI_BACKEND
    PEPPI_BACKEND --> PARALLEL_FETCH["Parallel Data Fetching
    Backend fetches all data sources
    simultaneously to assemble prompt"]

    %% =================== DATA SOURCES ===================
    subgraph MYSQL_DB["MySQL Database: dashtech_peppi"]
        direction TB
        TBL_USERS["tbl_users
        Columns: id, name, age, gender,
        ethnicity, location, city, state,
        country, hobbies, favorite_foods"]

        TBL_BUDDIES["tbl_buddies
        Columns: id, name, age, gender,
        location, education, personality,
        humor_style, relationship_type,
        impairments, language,
        life_story_summary"]

        TBL_ROUTINES["tbl_buddy_routines
        Columns: id, buddy_id, date,
        summary, activity
        Activity sections per day:
        MORNING, WORK, AFTERNOON,
        EVENING, NIGHT"]

        TBL_CHAT["tbl_chat_history
        Columns: id, user_id, buddy_id,
        role, content, created_at"]

        TBL_SMS_CONFIG["tbl_sms_config / System Config
        Columns: user_id,
        sms_remaining, token_rules"]
    end

    subgraph VECTOR_DB["Vector Database - Semantic Search"]
        direction TB
        RAG_CHAT_SEARCH["RAG Chat Search Service
        URL: https://rag-pipeline.dashtechs.com/search
        Method: POST
        Cosine similarity on embedded
        chat conversation batches"]

        RAG_BUDDY_CONTEXT["RAG Buddy Context Service
        URL: https://rag-api.dashtechs.com/api/v1/buddy/buddy/context
        Method: POST
        Returns both Story Chunks
        and Routine Chunks in one call"]
    end

    PARALLEL_FETCH --> MYSQL_DB
    PARALLEL_FETCH --> VECTOR_DB

    %% =================== 8 PROMPT BLOCKS ===================
    subgraph PROMPT_ASSEMBLY["System Prompt Assembly - 8 Blocks in Sequential Order"]
        direction TB

        BLOCK1["BLOCK 1: Token Rules
        ─────────────────────────
        Source: Static / Hardcoded
        Applies to: ALL users, ALL buddies
        No database query needed
        ─────────────────────────
        Content:
        KEEP ALL RESPONSES UNDER 200 TOKENS. HARD RULE.
        - Stop before 200 tokens. Always finish your sentence completely.
        - Short, casual, SMS-style. No walls of text.
        - Cut filler. Be direct. One or two sentences max.
        - Never trail off or get cut mid-thought.
        - DO NOT mention this limit."]

        BLOCK2["BLOCK 2: Buddy Pre-Prompt
        ─────────────────────────
        Source: MySQL tbl_users + tbl_buddies
        Filter: WHERE tbl_users.id = user_id AND tbl_buddies.id = buddy_id
        ─────────────────────────
        Contains 6 sub-sections:
        1. YOUR MISSION - Static behavioral instructions for relationship building over SMS
        2. ABOUT ME - User profile: name=Tanmay Upasani, age=23, gender=Male,
           ethnicity=American Indian, location=New York, hobbies=chess,cricket,
           singing,reading,startup, foods=Pizza,biryani, current date/time, weather
        3. ABOUT YOU - Buddy profile: relationship=Friend, name=Jarvis, age=25,
           gender=Male, location=New York, education=Graduate degree,
           impairments=No impairments, language=English,
           personality=Enthusiastic,Creative,Supportive,
           humor=Sarcastic and Playful, current date/time, weather
        4. Life Story Summary - Full multi-paragraph generated backstory
           covering birth to present day
        5. Character Instructions - Stay in character, Relationship Tone Guide,
           Using Your Context, Familiarity Over Time, How To Text,
           What Not To Do, When They Are Struggling, Crisis Protocol,
           What You Do Not Do
        6. Safety Rules - No medical/financial/sexual/illegal content advice"]

        BLOCK3["BLOCK 3: Recent Routines - Last 2 Days
        ─────────────────────────
        Source: MySQL tbl_buddy_routines
        Query: SELECT * FROM tbl_buddy_routines
        WHERE buddy_id = 725
        AND date >= NOW() - INTERVAL 2 DAY
        ORDER BY date DESC
        LIMIT 3
        ─────────────────────────
        Returns 3 full day schedules, each containing:
        - Date and creation timestamp
        - Summary paragraph describing the day mood and theme
        - Activity broken into 5 time blocks:
          MORNING - Wake up, breakfast, commute
          WORK - Office tasks, meetings, lunch
          AFTERNOON - Meetings, focus blocks, walks
          EVENING - Commute home, dinner, personal time
          NIGHT - Wind down, reading, sleep
        - Each entry: exact time + detailed activity description
        Example dates returned: 2026-02-20, 2026-02-19, 2026-02-18"]

        BLOCK4["BLOCK 4: Recent Chat History - Last 25 Messages
        ─────────────────────────
        Source: MySQL tbl_chat_history
        Query: SELECT * FROM tbl_chat_history
        WHERE user_id = user_id
        ORDER BY created_at DESC
        LIMIT 25
        ─────────────────────────
        Returns chronological conversation pairs:
        - ISO timestamp per message
        - User name + user message text
        - Buddy name + buddy response text
        Example:
        Date: 2026-02-20T10:23:43.000000Z
        Tanmay Upasani: sure seeya bye
        Jarvis: yo catch you later man!"]

        BLOCK5["BLOCK 5: RAG Story Chunks - Top 5
        ─────────────────────────
        Source: Vector DB via RAG Buddy Context API
        Endpoint: POST https://rag-api.dashtechs.com/api/v1/buddy/buddy/context
        Payload:
          buddyId: 725
          userUuid: eff67a70-00f9-11f1-bbd8-ed635f290324
          query: user current message
        Response field: data.storyChunks
        ─────────────────────────
        Returns 5 life story chunks ranked by cosine similarity:
        - STAGE_01: Early Childhood age 0-5, life_phase=early_childhood
        - STAGE_02: Childhood age 6-10, life_phase=childhood
        - STAGE_03: Childhood age 11-15, life_phase=childhood
        - STAGE_04: Adolescence age 16-20, life_phase=adolescence
        - STAGE_05: Young Adult age 21-25, life_phase=young_adult
        Each chunk has: chunkId, contentType=story, text,
        metadata with age_range and life_phase, relevanceScore
        Chunks separated by the delimiter marker in prompt
        Prefixed with: Here is some information about the story:"]

        BLOCK6["BLOCK 6: RAG Routine Chunks - Top 5
        ─────────────────────────
        Source: Same API call as Block 5
        Same Endpoint: POST https://rag-api.dashtechs.com/api/v1/buddy/buddy/context
        Same Payload: buddyId=725, userUuid, query
        Response field: data.routineChunks
        ─────────────────────────
        Returns 5 past daily schedules ranked by cosine similarity:
        Each chunk contains:
        - chunkId: routine_725_YYYY-MM-DD
        - contentType: routine
        - Full day schedule text with MORNING through NIGHT sections
        - metadata: routine_id, date, day_of_week, summary
        - relevanceScore
        Example dates: 2026-02-13, 2026-02-14, 2026-02-11, 2026-02-15, 2026-02-19
        Prefixed with: Here is some information about the previous routine:"]

        BLOCK7["BLOCK 7: RAG Past Chat Chunks - Up to 5 Batches
        ─────────────────────────
        Source: Vector DB via RAG Chat Search API
        Endpoint: POST https://rag-pipeline.dashtechs.com/search
        Payload:
          user_uuid: eff67a70-00f9-11f1-bbd8-ed635f290324
          collection_name: peppi_chat_production
          query: user current message
          limit: 5
        ─────────────────────────
        Returns up to 5 results, each a Consolidated Batch of 15 messages:
        Each result contains:
        - score: cosine distance score
        - similarity_score: normalized similarity
        - question: Consolidated Batch 15 messages label
        - answer: Full Q and A conversation text with all 15 pairs
        - timestamp: batch creation date
        - memory_type: episodic
        - importance_score: 0.5
        - days_ago, user_id, user_name
        Prefixed with: Here are related past chats:"]

        BLOCK8["BLOCK 8: Date/Time + SMS Remaining + Token Reminder
        ─────────────────────────
        Source: MySQL + System Clock
        ─────────────────────────
        Injected at end of system prompt:
        - Current date and time at user location
        - Current date and time at buddy location
        - Weather information for both locations
        - SMS messages remaining for the user
        - Final token limit enforcement reminder"]

        BLOCK1 -.-> BLOCK2
        BLOCK2 -.-> BLOCK3
        BLOCK3 -.-> BLOCK4
        BLOCK4 -.-> BLOCK5
        BLOCK5 -.-> BLOCK6
        BLOCK6 -.-> BLOCK7
        BLOCK7 -.-> BLOCK8
    end

    %% =================== DATA FLOW CONNECTIONS ===================

    %% Block 1 - Static
    TBL_SMS_CONFIG -->|"Static rules, no query needed
    Same text for every user"| BLOCK1

    %% Block 2 - User + Buddy profiles
    TBL_USERS -->|"SELECT * FROM tbl_users
    WHERE id = user_id
    Returns: name, age, gender,
    ethnicity, location, hobbies,
    favorite_foods"| BLOCK2

    TBL_BUDDIES -->|"SELECT * FROM tbl_buddies
    WHERE id = buddy_id
    Returns: name, age, gender,
    location, education, personality,
    humor_style, relationship_type,
    life_story_summary"| BLOCK2

    %% Block 3 - Recent Routines
    TBL_ROUTINES -->|"SELECT * FROM tbl_buddy_routines
    WHERE buddy_id = 725
    AND date >= NOW() - INTERVAL 2 DAY
    ORDER BY date DESC LIMIT 3"| BLOCK3

    %% Block 4 - Chat History
    TBL_CHAT -->|"SELECT * FROM tbl_chat_history
    WHERE user_id = user_id
    ORDER BY created_at DESC
    LIMIT 25"| BLOCK4

    %% Block 5 - RAG Story Chunks
    RAG_BUDDY_CONTEXT -->|"POST request with:
    buddyId: 725
    userUuid: eff67a70-00f9-11f1-bbd8-ed635f290324
    query: user current message
    Returns: data.storyChunks array of 5 chunks
    Each with chunkId, text, metadata, relevanceScore"| BLOCK5

    %% Block 6 - RAG Routine Chunks
    RAG_BUDDY_CONTEXT -->|"Same API response as Block 5
    Returns: data.routineChunks array of 5 chunks
    Each with chunkId, text, metadata, relevanceScore"| BLOCK6

    %% Block 7 - RAG Past Chats
    RAG_CHAT_SEARCH -->|"POST request with:
    user_uuid: eff67a70-00f9-11f1-bbd8-ed635f290324
    collection_name: peppi_chat_production
    query: user current message
    limit: 5
    Returns: results array of up to 5 batches
    Each batch = 15 message Q and A pairs"| BLOCK7

    %% Block 8 - System metadata
    TBL_SMS_CONFIG -->|"User SMS remaining count
    + system clock datetime
    + weather API data"| BLOCK8

    %% =================== FINAL OUTPUT ===================
    BLOCK8 --> FINAL_PROMPT["Final Assembled Prompt
    ─────────────────────────
    Array Structure:
    Array index 0 = Complete system prompt
    containing all 8 blocks concatenated
    Array index 1 = User current message
    role: user, content: Hey, how are you"]

    FINAL_PROMPT --> LLM_ENGINE["AI Model: Claude or GPT
    ─────────────────────────
    Receives:
    - System prompt with all 8 blocks as context
    - User current message as the input
    Generates response following all rules"]

    LLM_ENGINE --> BUDDY_RESPONSE["Buddy Response Generated
    ─────────────────────────
    Under 200 tokens
    SMS-style plain text
    No markdown, no lists, no formatting
    Stays in character as Jarvis
    Matches user energy and relationship depth"]

    BUDDY_RESPONSE --> STORE_AND_SEND["Store in tbl_chat_history
    + Send via Twilio SMS
    to User Phone Number"]

    STORE_AND_SEND --> USER_SMS

    %% =================== STYLING ===================
    classDef sourceDB fill:#4a90d9,stroke:#2c5f8a,color:#ffffff,stroke-width:2px
    classDef vectorDB fill:#7b68ee,stroke:#5a4fcf,color:#ffffff,stroke-width:2px
    classDef block fill:#2ecc71,stroke:#1a9c54,color:#ffffff,stroke-width:2px
    classDef entry fill:#e74c3c,stroke:#c0392b,color:#ffffff,stroke-width:2px
    classDef output fill:#f39c12,stroke:#d68910,color:#ffffff,stroke-width:2px
    classDef process fill:#3498db,stroke:#2980b9,color:#ffffff,stroke-width:2px

    class TBL_USERS,TBL_BUDDIES,TBL_ROUTINES,TBL_CHAT,TBL_SMS_CONFIG sourceDB
    class RAG_CHAT_SEARCH,RAG_BUDDY_CONTEXT vectorDB
    class BLOCK1,BLOCK2,BLOCK3,BLOCK4,BLOCK5,BLOCK6,BLOCK7,BLOCK8 block
    class USER_SMS,PEPPI_BACKEND entry
    class FINAL_PROMPT,LLM_ENGINE,BUDDY_RESPONSE,STORE_AND_SEND output
    class PARALLEL_FETCH process

# ==========================================
# Moltbot Render Environment Variables
# ==========================================

# Supabase Database
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your_service_role_key_here

# Upstash Redis (from Upstash dashboard)
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://your-render-app.onrender.com/api/v1/oauth/google/callback

# Encryption (auto-generated on Render). PRIMARY key — all new tokens encrypt with it.
ENCRYPTION_KEY=

# Retired encryption keys, comma-separated. Optional; used ONLY during a key rotation so
# tokens encrypted with the previous key still decrypt (MultiFernet keyring).
# Rotate: ENCRYPTION_KEYS_OLD=<current key> → ENCRYPTION_KEY=<new key> → deploy →
# re-encrypt at rest → clear ENCRYPTION_KEYS_OLD.
ENCRYPTION_KEYS_OLD=

# API Secret (auto-generated on Render)
API_SECRET_KEY=

# Shared service-to-service key. Trusted internal callers (Peppi Laravel, the
# gateway) send it as X-Moltbot-Key. Must be identical on moltbot-fastapi,
# openclaw-gateway, and Peppi Laravel. Guarded routes fail closed (503) if unset.
INTERNAL_SERVICE_KEY=

# Moltbot Gateway. HTTPS ONLY — the Google access token is sent to the gateway in the
# request body, so a plaintext http:// value would put it on the wire in clear.
MOLTBOT_GATEWAY_URL=https://openclaw-gateway-dg3y.onrender.com

# Peppi Website
PEPPI_WEBSITE_URL=https://peppi.app

# CORS allow-list — comma-separated exact origins (scheme://host[:port]).
# EMPTY (the default) = no cross-origin browser access at all, which is correct today:
# every data-bearing route requires the X-Moltbot-Key header, which no browser can hold.
ALLOWED_ORIGINS=

# Max accepted request body in bytes (default 5 MiB = 5242880, matching the gateway).
MAX_REQUEST_BODY_BYTES=

# Upstash QStash (Reminder Scheduling)
QSTASH_URL="https://qstash-eu-central-1.upstash.io"
QSTASH_TOKEN=your_qstash_token_here
QSTASH_CURRENT_SIGNING_KEY=your_qstash_current_signing_key_here
QSTASH_NEXT_SIGNING_KEY=your_qstash_next_signing_key_here

# Peppi Outbound SMS
PEPPI_OUTBOUND_URL=
PEPPI_OUTBOUND_API_KEY=

# Moltbot Public URL (for QStash webhook callbacks)
MOLTBOT_PUBLIC_URL=https://moltbot-fastapi.onrender.com
